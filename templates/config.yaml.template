# archon-board-review configuration
# Generated by: archon-board-review setup
# Edit to customize agent models, CLIs, and paths

# Archon workflow defaults location (auto-detected during setup)
archon_defaults: __ARCHON_DEFAULTS__

# Board workspace (agent directories, inbox/outbox)
board_dir: __HOME__/.archon-board-review/board

# Board user — leave empty to run agents as current user
# Set to a dedicated user (e.g., llmuser) for process isolation
board_user:

# Agent configuration
# Each agent needs: cli (claude or codex), model, flags, timeout (seconds)
# Swap models freely — use whatever you have access to
agents:
  pragmatist:
    cli: claude
    model: claude-opus-4-6
    flags: "--dangerously-skip-permissions"
    timeout: 900
  systems-thinker:
    cli: codex
    model: gpt-5.2-codex
    flags: "--dangerously-bypass-approvals-and-sandbox"
    timeout: 900
  skeptic:
    cli: claude
    model: deepseek/deepseek-v3.2
    flags: "--dangerously-skip-permissions"
    timeout: 900

# Examples of alternative agent configurations:
#
# All Claude (no Codex or OpenRouter needed):
#   pragmatist:  { cli: claude, model: claude-opus-4-6 }
#   systems-thinker: { cli: claude, model: claude-sonnet-4-6 }
#   skeptic:     { cli: claude, model: claude-opus-4-6 }
#
# Claude + Gemini:
#   skeptic:     { cli: claude, model: google/gemini-2.5-pro }
